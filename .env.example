# Required Spotify OAuth settings
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_USERNAME=your_spotify_username

# Optional app settings
DJ_SYNC_DB_PATH=./dj_spotify_sync/dj_sync.db
DJ_SYNC_GENRE_MAP=./dj_spotify_sync/config/genre_map.json
DJ_SYNC_MATCH_THRESHOLD=70
DJ_SYNC_UNSORTED_PLAYLIST=Unsorted
SPOTIFY_MARKET=US
